{
  "name": "pg2oracle",
  "version": "0.1.3",
  "description": "Translate PostgreSQL DDL to Oracle DDL. File in, file out. Honest about what it can't do.",
  "license": "MIT",
  "author": "Sam <sam@getboltway.com>",
  "homepage": "https://github.com/Mastery-Business-Solutions-of-America/pg2oracle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mastery-Business-Solutions-of-America/pg2oracle.git"
  },
  "bugs": {
    "url": "https://github.com/Mastery-Business-Solutions-of-America/pg2oracle/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "oracle",
    "oracle-database",
    "migration",
    "ddl",
    "schema",
    "sql",
    "translate",
    "converter",
    "transpiler",
    "pg_dump",
    "database",
    "cli",
    "diligence",
    "assessment",
    "compatibility-report"
  ],
  "type": "module",
  "bin": {
    "pg2oracle": "./dist/cli.cjs"
  },
  "files": [
    "dist/cli.cjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:dev": "node scripts/dev-stub.mjs",
    "dev": "node scripts/dev-stub.mjs",
    "start": "node dist/cli.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "uat": "bash scripts/uat.sh",
    "typecheck": "tsc --noEmit",
    "verify": "bun run typecheck && bun run test && bun run build && bun run uat",
    "verify:ci": "bun run typecheck && bun run test && bun run build",
    "prepublishOnly": "bun run verify:ci"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.4",
    "commander": "^12.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}

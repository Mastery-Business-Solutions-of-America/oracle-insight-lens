{
  "name": "pg2ora",
  "version": "0.1.0",
  "description": "Translate PostgreSQL DDL to Oracle DDL. File in, file out. Honest about what it can't do.",
  "license": "MIT",
  "author": "Sam <sam@getboltway.com>",
  "type": "module",
  "bin": {
    "pg2ora": "./dist/cli.cjs"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/cli.cjs --banner:js=\"#!/usr/bin/env node\" && chmod +x dist/cli.cjs",
    "build:dev": "node scripts/dev-stub.mjs",
    "dev": "node scripts/dev-stub.mjs",
    "start": "node dist/cli.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "uat": "bash scripts/uat.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pgsql-ast-parser": "^12.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}

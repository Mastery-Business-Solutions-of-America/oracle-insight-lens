{
  "name": "pg2oracle",
  "version": "0.1.0",
  "description": "Translate PostgreSQL DDL to Oracle DDL. File in, file out. Honest about what it can't do.",
  "license": "MIT",
  "author": "Sam <sam@getboltway.com>",
  "homepage": "https://github.com/Mastery-Business-Solutions-of-America/oracle-insight-lens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mastery-Business-Solutions-of-America/oracle-insight-lens.git"
  },
  "bugs": {
    "url": "https://github.com/Mastery-Business-Solutions-of-America/oracle-insight-lens/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "oracle",
    "migration",
    "ddl",
    "schema",
    "sql",
    "translate",
    "converter",
    "pg_dump",
    "database",
    "cli"
  ],
  "type": "module",
  "bin": {
    "pg2oracle": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:dev": "node scripts/dev-stub.mjs",
    "dev": "node scripts/dev-stub.mjs",
    "start": "node dist/cli.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "uat": "bash scripts/uat.sh",
    "typecheck": "tsc --noEmit",
    "verify": "bun run typecheck && bun run test && bun run build && bun run uat",
    "prepublishOnly": "bun run verify"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.4",
    "commander": "^12.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
